# 部署至新主機時，請將此檔案複製為 .env 並填入所有正確數值
# cp .env.example .env

# -----------------------------------------------------------------------
# [必填] 安全憑證 - 請勿使用預設值，必須自行產生隨機字串
# -----------------------------------------------------------------------

# JWT 簽名密鑰：請使用 `python -c "import secrets; print(secrets.token_hex(32))"` 產生
AXIS_JWT_SECRET=<請填入 64 字元以上的隨機字串>

# 管理員初始密碼：首次啟動服務時會以此建立 sparkle 帳號
AXIS_ADMIN_PASS=<請填入管理員初始密碼>

# -----------------------------------------------------------------------
# [必填] Proxmox VE 連線設定
# -----------------------------------------------------------------------
PVE_HOST=192.168.0.138
PVE_USER=root@pam
PVE_PASS=<請填入 Proxmox 密碼>

# -----------------------------------------------------------------------
# [必填] IoT 與外部服務 Token
# -----------------------------------------------------------------------
BLYNK_TOKEN=<請填入 Blynk IoT Token>
GITHUB_TOKEN=<請填入 GitHub Personal Access Token>
CLOUDFLARE_TUNNEL_TOKEN=<請填入 Cloudflare Tunnel Token>

# -----------------------------------------------------------------------
# [選填] 網路與路徑設定
# -----------------------------------------------------------------------

# API 監聽 IP：0.0.0.0 表示監聽所有介面
HOST_IP=0.0.0.0

# CORS 允許來源：多個來源用逗號分隔，留 * 表示允許全部（不建議用於生產）
ALLOWED_ORIGINS=https://absoluteaxis.dpdns.org

# 專案根路徑：留空則自動偵測
AXIS_BASE_PATH=

# NAS 儲存路徑：留空則使用 AXIS_BASE_PATH/nas
AXIS_NAS_PATH=

# 系統根路徑（用於磁碟計算）：Linux 填 /，Windows 填 C:\
AXIS_SYS_ROOT=/
