import sqlite3
import os

db_path = 'e:/absolute axis/axis.db'
if os.path.exists(db_path):
    conn = sqlite3.connect(db_path)
    cursor = conn.cursor()
    # 100GB = 100 * 1024 * 1024 * 1024
    new_quota = 100 * 1024 * 1024 * 1024
    cursor.execute("UPDATE users SET quota_bytes = ? WHERE username = 'sparkle'", (new_quota,))
    conn.commit()
    print(f"Updated sparkle's quota to {new_quota} bytes.")
    conn.close()
else:
    print("Database not found at e:/absolute axis/axis.db")
