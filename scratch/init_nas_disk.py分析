import paramiko

def run_cmd_on_vm(command):
    pve_client = paramiko.SSHClient()
    pve_client.set_missing_host_key_policy(paramiko.AutoAddPolicy())
    pve_client.connect('100.124.203.61', username='root', password='deven951130', timeout=10)
    
    vm_ip = '192.168.0.159'
    vm_user = 'sparkle'
    vm_pass = '951130'
    
    transport = pve_client.get_transport()
    channel = transport.open_channel("direct-tcpip", (vm_ip, 22), ('100.124.203.61', 22))
    
    vm_client = paramiko.SSHClient()
    vm_client.set_missing_host_key_policy(paramiko.AutoAddPolicy())
    vm_client.connect(vm_ip, username=vm_user, password=vm_pass, sock=channel)
    
    # Prepend password for sudo
    sudo_cmd = f"echo {vm_pass} | sudo -S bash -c \"{command}\""
    stdin, stdout, stderr = vm_client.exec_command(sudo_cmd)
    out = stdout.read().decode(errors='replace')
    err = stderr.read().decode(errors='replace')
    
    vm_client.close()
    pve_client.close()
    return out, err

print("--- Initializing 5.5T disk (sdb) on VM ---")
init_disk_cmds = """
if ! blkid /dev/sdb; then
  echo 'Creating partition and formatting /dev/sdb...'
  parted /dev/sdb mklabel gpt
  parted /dev/sdb mkpart primary ext4 0% 100%
  mkfs.ext4 /dev/sdb1
fi
"""
out, err = run_cmd_on_vm(init_disk_cmds)
print(out)

print("--- Mounting to nas folder ---")
mount_cmds = """
mkdir -p /home/sparkle/Absolute-Axis/nas
if ! mount | grep /home/sparkle/Absolute-Axis/nas; then
  mount /dev/sdb1 /home/sparkle/Absolute-Axis/nas || mount /dev/sdb /home/sparkle/Absolute-Axis/nas
fi
chown -R sparkle:sparkle /home/sparkle/Absolute-Axis/nas
"""
out, err = run_cmd_on_vm(mount_cmds)
print(out)

print("--- Adding to /etc/fstab ---")
fstab_cmds = """
UUID=$(blkid -s UUID -o value /dev/sdb1 || blkid -s UUID -o value /dev/sdb)
if [ -n "$UUID" ] && ! grep "$UUID" /etc/fstab; then
  echo "UUID=$UUID /home/sparkle/Absolute-Axis/nas ext4 defaults 0 2" >> /etc/fstab
fi
"""
run_cmd_on_vm(fstab_cmds)

print("\n--- Final mount check ---")
# Need a separate command for df to see it without sudo if possible, or just use it
out, err = run_cmd_on_vm("df -h /home/sparkle/Absolute-Axis/nas")
print(out)
